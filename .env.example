# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# MySQL root password — change before deploying
MYSQL_ROOT_PASSWORD=changeme

# JWT signing secret — must be Base64-encoded, min 32 chars decoded
# Generate one: openssl rand -base64 32
JWT_SECRET=dGVhbWZsb3ctc2VjcmV0LWtleS10aGF0LWlzLWxvbmctZW5vdWdoLWZvci1IUzI1Ng==

# Token lifetime in ms (86400000 = 24 h)
JWT_EXPIRATION_MS=86400000
